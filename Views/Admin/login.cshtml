@model latihan.Models.User

@{
    Layout = null; 
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --accent-color: #6366f1;
            --dark-slate: #0f172a;
            --glass-bg: rgba(255, 255, 255, 0.95);
        }

        body {
            /* Background gradasi halus agar tidak terlalu mencolok */
            background: radial-gradient(circle at top right, #eef2ff, #f1f5f9);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-radius: 28px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            overflow: hidden;
        }

        .login-header {
            background: var(--dark-slate);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .login-icon-wrapper {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 1.8rem;
            color: #818cf8;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card-body {
            padding: 40px;
        }

        /* Label Styling (Sama dengan Editor) */
        .form-label {
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #94a3b8;
            margin-bottom: 8px;
        }

        /* Input Group Modern */
        .input-group-custom {
            position: relative;
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            color: #94a3b8;
            font-size: 1.1rem;
            z-index: 10;
        }

        .form-control-custom {
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 12px 15px 12px 45px;
            font-size: 0.95rem;
            width: 100%;
            transition: 0.3s;
            background: #f8fafc;
        }

        .form-control-custom:focus {
            background: #fff;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            outline: none;
        }

        .btn-login {
            background: var(--accent-color);
            border: none;
            border-radius: 14px;
            padding: 14px;
            font-weight: 700;
            color: white;
            width: 100%;
            margin-top: 10px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-login:hover {
            background: #4f46e5;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2);
        }

        .error-message {
            background-color: #fff1f2;
            color: #e11d48;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 25px;
            font-size: 0.85rem;
            border: 1px solid #fecdd3;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .back-home {
            text-align: center;
            margin-top: 25px;
        }

        .back-home a {
            color: #64748b;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            transition: 0.2s;
        }

        .back-home a:hover {
            color: var(--accent-color);
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-icon-wrapper">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h4 class="fw-bold mb-1">Admin Portal</h4>
                <p class="mb-0 opacity-50 small text-uppercase tracking-wider">Authentication Required</p>
            </div>
            
            <div class="card-body">
                @if (TempData["Error"] != null)
                {
                    <div class="error-message">
                        <i class="bi bi-exclamation-circle-fill"></i> 
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <form asp-controller="Admin" asp-action="Auth" method="post">
                    <div class="mb-1">
                        <label class="form-label">Username</label>
                        <div class="input-group-custom">
                            <i class="bi bi-person input-icon"></i>
                            <input type="text" name="username" class="form-control-custom" placeholder="Nama pengguna" required autofocus />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Password</label>
                        <div class="input-group-custom">
                            <i class="bi bi-key input-icon"></i>
                            <input type="password" name="password" class="form-control-custom" placeholder="Kata sandi" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login">
                        Masuk ke Sistem <i class="bi bi-arrow-right-short fs-4"></i>
                    </button>
                </form>
            </div>
        </div>
        
        <div class="back-home">
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door me-1"></i> Kembali ke Beranda
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>