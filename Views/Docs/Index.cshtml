@model IEnumerable<latihan.Models.Post>
@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentFilter = ViewBag.CurrentFilter ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --brand-dark: #1e293b;
        --brand-indigo: #6366f1;
        --brand-slate: #94a3b8;
        --text-elegant: #334155;
        --bg-body: #f1f5f9;
        --border-soft: #e2e8f0;
    }

    body { 
        background-color: var(--bg-body); 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        color: var(--text-elegant);
    }

    .compact-container {
        max-width: 1100px; 
        margin: 0 auto;
        padding: 0 25px;
    }

    /* --- HERO SECTION --- */
    .hero-section {
        background-color: #ffffff;
        padding: 60px 0 65px;
        border-bottom: 1px solid var(--border-soft);
        background-image: radial-gradient(#cbd5e1 0.8px, transparent 0.8px);
        background-size: 24px 24px;
    }

    .brand-accent {
        height: 4px; width: 40px;
        background: var(--brand-indigo);
        margin: 0 auto 20px;
        border-radius: 10px;
    }

    /* --- SEARCH BOX --- */
    .search-container {
        max-width: 550px;
        margin: -30px auto 50px;
        position: relative;
        z-index: 10;
    }

    .search-input-elegant {
        border: 2px solid var(--border-soft);
        border-radius: 16px;
        padding: 16px 20px 16px 60px;
        font-size: 0.95rem;
        background: white;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    .search-input-elegant:focus {
        border-color: var(--brand-indigo);
        outline: none;
        box-shadow: 0 20px 30px -10px rgba(99, 102, 241, 0.15);
    }

    .search-icon-elegant {
        position: absolute;
        left: 22px; top: 50%;
        transform: translateY(-50%);
        color: var(--brand-slate);
        font-size: 1.2rem;
    }

    /* --- CARD DESIGN --- */
    .doc-card-item {
        opacity: 0;
        animation: cardAppear 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    }

    .card-doc-elegant {
        border: 1px solid var(--border-soft);
        border-radius: 24px;
        background: white;
        transition: all 0.4s ease;
        padding: 30px;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .card-doc-elegant:hover {
        transform: translateY(-8px);
        border-color: var(--brand-indigo);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.1);
    }

    .category-label {
        font-size: 0.7rem; font-weight: 800;
        text-transform: uppercase;
        color: var(--brand-indigo);
        margin-bottom: 15px;
        display: flex; align-items: center; gap: 8px;
        background: #f5f3ff; width: fit-content;
        padding: 4px 12px; border-radius: 8px;
    }

    .doc-title-elegant {
        color: var(--brand-dark); font-weight: 800; font-size: 1.15rem;
        margin-bottom: 12px; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden; min-height: 3.2em; 
    }

    /* --- ANIMATIONS (Fix Error @@) --- */
    @@keyframes cardAppear {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .searching-loader {
        animation: spin 1s linear infinite;
        color: var(--brand-indigo) !important;
    }

    @@keyframes spin {
        from { transform: translateY(-50%) rotate(0deg); }
        to { transform: translateY(-50%) rotate(360deg); }
    }

    #searchResultArea {
        transition: opacity 0.3s ease;
    }
</style>

<section class="hero-section text-center">
    <div class="compact-container">
        <div class="brand-accent"></div>
        <h2 class="fw-800 mb-2" style="font-weight: 800; color: var(--brand-dark);">Digital Library</h2>
        <p class="text-muted small mb-0 fw-600" style="letter-spacing: 0.2em; font-size: 0.7rem;">PT SEPATU MAS IDAMAN</p>
    </div>
</section>

<div class="compact-container">
    <form id="searchForm" asp-action="Index" method="get" class="search-container">
        <i id="statusIcon" class="bi bi-search search-icon-elegant"></i>
        <input type="text" name="searchString" id="searchInput" class="form-control search-input-elegant" 
               placeholder="Cari instruksi kerja..." value="@currentFilter" autocomplete="off">
    </form>

    <div id="searchResultArea">
        <div class="row g-4 mb-4" id="docGrid">
            @if (!Model.Any()) {
                <div class="col-12 text-center py-5">
                    <div class="py-5" style="background: white; border-radius: 24px; border: 2px dashed var(--border-soft);">
                        <i class="bi bi-search" style="font-size: 3rem; color: var(--brand-slate);"></i>
                        <p class="mt-3 fw-600" style="color: var(--brand-slate);">
                            @(string.IsNullOrEmpty(currentFilter) ? "Belum ada dokumen." : $"Hasil untuk '{currentFilter}' tidak ditemukan.")
                        </p>
                    </div>
                </div>
            } else {
                @foreach (var item in Model) {
                    <div class="col-md-6 col-lg-4 doc-card-item">
                        <div class="card-doc-elegant">
                            <span class="category-label"><i class="bi bi-shield-check"></i> Terverifikasi</span>
                            <h5 class="doc-title-elegant">@item.Title</h5>
                            <p style="font-size: 0.85rem; opacity: 0.8; margin-bottom: 25px;">
                                Pedoman standar operasional mengenai @item.Title.
                            </p>
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-4 border-top">
                                <div style="font-size: 0.75rem; color: var(--brand-slate); font-weight: 600;">
                                    <i class="bi bi-clock-history"></i> @item.CreatedAt.ToString("MMM yyyy")
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" style="text-decoration:none; color:var(--brand-dark); font-weight:700; font-size:0.75rem;">
                                    BUKA <i class="bi bi-arrow-right-short" style="font-size: 1.2rem;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @if (totalPages > 1) {
            <nav class="mb-5">
                <ul class="pagination justify-content-end">
                    @for (int i = 1; i <= totalPages; i++) {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link ajax-page-link" href="?page=@i&searchString=@currentFilter">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const searchForm = document.getElementById('searchForm');
        const statusIcon = document.getElementById('statusIcon');
        const resultArea = document.getElementById('searchResultArea');
        let timer;

        // Fungsi Cari via AJAX (Sangat Ringan)
        async function doSearch() {
            const query = searchInput.value;
            const url = `@Url.Action("Index")?searchString=${encodeURIComponent(query)}`;

            // Efek Loading Transparan
            resultArea.style.opacity = '0.5';

            try {
                const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const text = await response.text();
                
                // Ambil konten baru dan ganti
                const parser = new DOMParser();
                const htmlDoc = parser.parseFromString(text, 'text/html');
                const newHtml = htmlDoc.getElementById('searchResultArea').innerHTML;
                
                resultArea.innerHTML = newHtml;
                
                // Update URL tanpa reload
                window.history.pushState({}, '', url);
                
            } catch (err) {
                console.error("Gagal memuat:", err);
            } finally {
                resultArea.style.opacity = '1';
                statusIcon.classList.replace('bi-arrow-repeat', 'bi-search');
                statusIcon.classList.remove('searching-loader');
                initCardAnimations();
            }
        }

        searchInput.addEventListener('input', () => {
            // Animasi Ikon
            statusIcon.classList.replace('bi-search', 'bi-arrow-repeat');
            statusIcon.classList.add('searching-loader');

            clearTimeout(timer);
            timer = setTimeout(doSearch, 400); // Tunggu 400ms setelah mengetik
        });

        // Mencegah reload saat tekan Enter
        searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            doSearch();
        });

        function initCardAnimations() {
            const cards = document.querySelectorAll('.doc-card-item');
            cards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.05}s`;
            });
        }

        window.addEventListener('DOMContentLoaded', initCardAnimations);
    </script>
}