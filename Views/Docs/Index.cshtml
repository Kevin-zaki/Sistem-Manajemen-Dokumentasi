@model IEnumerable<latihan.Models.Post>
@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentFilter = ViewBag.CurrentFilter ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --brand-dark: #1e293b;
        --brand-indigo: #6366f1;
        --brand-slate: #94a3b8;
        --text-elegant: #334155;
        --bg-body: #f1f5f9;
        --border-soft: #e2e8f0;
        --card-bg: #ffffff;
        --search-bg: #ffffff;
        --hero-bg: #ffffff;
        --dot-color: #cbd5e1;
    }

    [data-bs-theme="dark"] {
        --brand-dark: #f8fafc;
        --brand-indigo: #818cf8;
        --brand-slate: #64748b;
        --text-elegant: #cbd5e1;
        --bg-body: #020617;
        --border-soft: #1e293b;
        --card-bg: #0f172a;
        --search-bg: #1e293b;
        --hero-bg: #020617;
        --dot-color: #1e293b;
    }

    body { 
        background-color: var(--bg-body); 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        color: var(--text-elegant);
        transition: background-color 0.3s ease;
    }

    .compact-container {
        max-width: 1100px; 
        margin: 0 auto;
        padding: 0 25px;
    }

    /* --- HERO SECTION --- */
    .hero-section {
        background-color: var(--hero-bg);
        padding: 60px 0 65px;
        border-bottom: 1px solid var(--border-soft);
        background-image: radial-gradient(var(--dot-color) 0.8px, transparent 0.8px);
        background-size: 24px 24px;
    }

    .brand-accent {
        height: 4px; width: 40px;
        background: var(--brand-indigo);
        margin: 0 auto 20px;
        border-radius: 10px;
    }

    /* --- SEARCH BOX --- */
    .search-container {
        max-width: 550px;
        margin: -30px auto 50px;
        position: relative;
        z-index: 10;
    }

    .search-input-elegant {
        border: 2px solid var(--border-soft);
        border-radius: 16px;
        padding: 16px 20px 16px 60px;
        font-size: 0.95rem;
        background: var(--search-bg);
        color: var(--brand-dark);
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    .search-input-elegant:focus {
        border-color: var(--brand-indigo);
        outline: none;
        box-shadow: 0 20px 30px -10px rgba(99, 102, 241, 0.15);
    }

    .search-icon-elegant {
        position: absolute;
        left: 22px; top: 50%;
        transform: translateY(-50%);
        color: var(--brand-slate);
        font-size: 1.2rem;
    }

    /* --- CARD DESIGN --- */
    .card-doc-elegant {
        border: 1px solid var(--border-soft);
        border-radius: 24px;
        background: var(--card-bg);
        transition: all 0.4s ease;
        padding: 30px;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .card-doc-elegant:hover {
        transform: translateY(-8px);
        border-color: var(--brand-indigo);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.2);
    }

    .category-label {
        font-size: 0.7rem; font-weight: 800;
        text-transform: uppercase;
        color: var(--brand-indigo);
        margin-bottom: 15px;
        display: flex; align-items: center; gap: 8px;
        background: rgba(99, 102, 241, 0.1); 
        padding: 4px 12px; border-radius: 8px;
        width: fit-content;
    }

    .doc-title-elegant {
        color: var(--brand-dark); font-weight: 800; font-size: 1.15rem;
        margin-bottom: 12px; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden; min-height: 3.2em; 
    }

    .doc-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-soft);
    }

    .doc-link {
        text-decoration: none;
        color: var(--brand-dark);
        font-weight: 700;
        font-size: 0.75rem;
    }

    .doc-link:hover { color: var(--brand-indigo); }

    /* --- PAGINATION --- */
    .pagination .page-link {
        background-color: var(--card-bg);
        border-color: var(--border-soft);
        color: var(--brand-indigo);
        border-radius: 10px;
        margin: 0 3px;
        font-weight: 600;
        padding: 8px 16px;
    }

    .pagination .page-item.active .page-link {
        background-color: var(--brand-indigo);
        border-color: var(--brand-indigo);
        color: white;
    }

    /* --- ANIMATIONS --- */
    .doc-card-item {
        opacity: 0;
        animation: cardAppear 0.5s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    }

    @@keyframes cardAppear {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .searching-loader {
        animation: spin 1s linear infinite;
        color: var(--brand-indigo) !important;
    }

    @@keyframes spin {
        from { transform: translateY(-50%) rotate(0deg); }
        to { transform: translateY(-50%) rotate(360deg); }
    }
</style>

<section class="hero-section text-center">
    <div class="compact-container">
        <div class="brand-accent"></div>
        <h2 class="fw-800 mb-2" style="font-weight: 800; color: var(--brand-dark);">Digital Library</h2>
        <p class="text-muted small mb-0 fw-600" style="letter-spacing: 0.2em; font-size: 0.7rem;">PT SEPATU MAS IDAMAN</p>
    </div>
</section>

<div class="compact-container">
    <form id="searchForm" asp-action="Index" method="get" class="search-container">
        <i id="statusIcon" class="bi bi-search search-icon-elegant"></i>
        <input type="text" name="searchString" id="searchInput" class="form-control search-input-elegant" 
               placeholder="Cari instruksi kerja..." value="@currentFilter" autocomplete="off">
    </form>

    <div id="searchResultArea">
        <div class="row g-4 mb-5" id="docGrid">
            @if (Model == null || !Model.Any()) {
                <div class="col-12 text-center py-5">
                    <div class="card-doc-elegant border-dashed justify-content-center align-items-center py-5" style="border: 2px dashed var(--border-soft); background: transparent;">
                        <i class="bi bi-search" style="font-size: 3rem; color: var(--brand-slate);"></i>
                        <p class="mt-3 fw-600" style="color: var(--brand-slate);">
                            @(string.IsNullOrEmpty(currentFilter) ? "Belum ada dokumen tersedia." : $"Hasil untuk '{currentFilter}' tidak ditemukan.")
                        </p>
                    </div>
                </div>
            } else {
                @foreach (var item in Model) {
                    <div class="col-md-6 col-lg-4 doc-card-item">
                        <div class="card-doc-elegant">
                            <span class="category-label"><i class="bi bi-shield-check"></i> Terverifikasi</span>
                            <h5 class="doc-title-elegant">@item.Title</h5>
                            <p class="text-muted small" style="font-size: 0.85rem; opacity: 0.8; margin-bottom: 25px;">
                                Pedoman standar operasional mengenai @item.Title untuk efisiensi produksi.
                            </p>
                            <div class="doc-footer">
                                <div style="font-size: 0.75rem; color: var(--brand-slate); font-weight: 600;">
                                    <i class="bi bi-clock-history"></i> @item.CreatedAt.ToString("MMM yyyy")
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="doc-link">
                                    BUKA <i class="bi bi-arrow-right-short" style="font-size: 1.2rem;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @* --- PAGINATION DENGAN LIMIT TAMPILAN (HANYA 3 HALAMAN) --- *@
        @if (totalPages > 1) {
            <nav class="mb-5">
                <ul class="pagination justify-content-center">
                    @* Tombol Previous *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(currentPage - 1)&searchString=@currentFilter"><i class="bi bi-chevron-left"></i></a>
                    </li>

                    @{
                        // Setting hanya 3 halaman yang tampil
                        int maxVisiblePages = 3; 
                        int startPage = Math.Max(1, currentPage - (maxVisiblePages / 2));
                        int endPage = Math.Min(totalPages, startPage + maxVisiblePages - 1);

                        // Koreksi jika startPage terlalu besar di akhir halaman
                        if (endPage - startPage < maxVisiblePages - 1) {
                            startPage = Math.Max(1, endPage - maxVisiblePages + 1);
                        }
                    }

                    @* Link Halaman Pertama jika startPage > 1 *@
                    @if (startPage > 1) {
                        <li class="page-item"><a class="page-link" href="?page=1&searchString=@currentFilter">1</a></li>
                        @if (startPage > 2) { <li class="page-item disabled"><span class="page-link">...</span></li> }
                    }

                    @* Looping Nomor Halaman (Maksimal 3) *@
                    @for (int i = startPage; i <= endPage; i++) {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i&searchString=@currentFilter">@i</a>
                        </li>
                    }

                    @* Link Halaman Terakhir jika endPage < totalPages *@
                    @if (endPage < totalPages) {
                        @if (endPage < totalPages - 1) { <li class="page-item disabled"><span class="page-link">...</span></li> }
                        <li class="page-item"><a class="page-link" href="?page=@totalPages&searchString=@currentFilter">@totalPages</a></li>
                    }

                    @* Tombol Next *@
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(currentPage + 1)&searchString=@currentFilter"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        const searchForm = document.getElementById('searchForm');
        const statusIcon = document.getElementById('statusIcon');
        const resultArea = document.getElementById('searchResultArea');
        let timer;

        async function doSearch() {
            const query = searchInput.value;
            const url = `@Url.Action("Index")?searchString=${encodeURIComponent(query)}`;
            resultArea.style.opacity = '0.5';

            try {
                const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const text = await response.text();
                const parser = new DOMParser();
                const htmlDoc = parser.parseFromString(text, 'text/html');
                const newHtml = htmlDoc.getElementById('searchResultArea').innerHTML;
                
                resultArea.innerHTML = newHtml;
                window.history.pushState({}, '', url);
            } catch (err) {
                console.error("Gagal memuat:", err);
            } finally {
                resultArea.style.opacity = '1';
                statusIcon.className = 'bi bi-search search-icon-elegant';
                initCardAnimations();
            }
        }

        searchInput.addEventListener('input', () => {
            statusIcon.className = 'bi bi-arrow-repeat search-icon-elegant searching-loader';
            clearTimeout(timer);
            timer = setTimeout(doSearch, 400);
        });

        searchForm.addEventListener('submit', (e) => { e.preventDefault(); doSearch(); });

        function initCardAnimations() {
            document.querySelectorAll('.doc-card-item').forEach((card, index) => {
                card.style.animationDelay = `${index * 0.05}s`;
            });
        }
        window.addEventListener('DOMContentLoaded', initCardAnimations);
    </script>
}   