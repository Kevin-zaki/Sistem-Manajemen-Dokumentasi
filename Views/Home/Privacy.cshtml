@{
    ViewData["Title"] = "Kebijakan Privasi";
}

<style>
    .privacy-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 60px 0;
        border-radius: 20px;
        margin-bottom: 40px;
    }
    .policy-card {
        border: none;
        border-left: 4px solid #0d6efd;
        background-color: #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border-radius: 0 15px 15px 0;
        margin-bottom: 25px;
        transition: transform 0.2s;
    }
    .policy-card:hover {
        transform: translateX(10px);
    }
    .icon-box {
        width: 50px;
        height: 50px;
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 15px;
    }
</style>

<div class="container py-5">
    <div class="privacy-header text-center shadow-sm">
        <h1 class="display-5 fw-bold text-dark">Kebijakan Privasi</h1>
        <p class="lead text-muted">Bagaimana kami mengelola dan melindungi informasi Anda.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            
            <div class="card policy-card p-4">
                <div class="icon-box">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h4>Keamanan Data Admin</h4>
                <p class="text-muted mb-0">
                    Sistem ini menggunakan enkripsi standar untuk melindungi kredensial login admin. Akses ke panel administrasi (Dashboard) hanya diberikan kepada personil yang berwenang melalui sistem otentikasi yang aman.
                </p>
            </div>

            <div class="card policy-card p-4">
                <div class="icon-box" style="background: rgba(25, 135, 84, 0.1); color: #198754;">
                    <i class="bi bi-file-earmark-check"></i>
                </div>
                <h4>Konten Dokumentasi</h4>
                <p class="text-muted mb-0">
                    Seluruh konten yang dipublikasikan dalam sistem dokumentasi ini bersifat internal/publik sesuai dengan pengaturan admin. Kami tidak membagikan data dokumen yang bersifat rahasia kepada pihak ketiga tanpa persetujuan.
                </div>

            <div class="card policy-card p-4">
                <div class="icon-box" style="background: rgba(253, 126, 20, 0.1); color: #fd7e14;">
                    <i class="bi bi-download"></i>
                </div>
                <h4>Unduhan File</h4>
                <p class="text-muted mb-0">
                    Setiap file yang diunduh dari sistem ini telah melalui proses scanning server. Pengguna diharapkan menggunakan file tersebut secara bijak sesuai dengan peruntukan teknisnya.
                </p>
            </div>

            <div class="text-center mt-5">
                <p class="text-muted small">Terakhir diperbarui: @DateTime.Now.ToString("dd MMMM yyyy")</p>
                <hr style="width: 50px; margin: 20px auto; border-top: 3px solid #dee2e6;">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary px-4">
                    <i class="bi bi-house-door me-2"></i>Kembali ke Beranda
                </a>
            </div>

        </div>
    </div>
</div>