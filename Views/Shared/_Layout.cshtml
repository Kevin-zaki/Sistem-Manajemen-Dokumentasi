<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SMI System</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --brand-primary: #6366f1; /* Indigo */
            --brand-dark: #0f172a;    /* Slate Dark */
            --bg-body: #f8fafc;
            --glass-bg: rgba(255, 255, 255, 0.8);
            --border-soft: rgba(0, 0, 0, 0.05);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--brand-dark);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            /* Padding top disesuaikan agar konten tidak tertutup navbar melayang */
            padding-top: 100px; 
        }

        main { flex: 1; }

        /* --- FLOATING NAVBAR --- */
        .navbar {
            background: var(--glass-bg) !important;
            backdrop-filter: blur(15px) saturate(180%);
            -webkit-backdrop-filter: blur(15px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            margin: 20px auto;
            padding: 12px 25px;
            border-radius: 20px;
            width: 92%;
            max-width: 1200px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
        }

        /* State saat Scroll */
        .navbar.scrolled {
            margin-top: 10px;
            padding: 8px 25px;
            background: rgba(255, 255, 255, 0.95) !important;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: -0.8px;
            display: flex;
            align-items: center;
            color: var(--brand-dark) !important;
        }

        .brand-icon {
            background: var(--brand-primary);
            color: white;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            margin-right: 12px;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);
        }

        /* Nav Links */
        .nav-link {
            font-size: 0.88rem;
            font-weight: 600;
            color: #64748b !important;
            padding: 8px 20px !important;
            margin: 0 2px;
            border-radius: 12px;
            transition: 0.3s;
        }

        .nav-link:hover {
            color: var(--brand-primary) !important;
            background: rgba(99, 102, 241, 0.06);
        }

        .nav-link.active {
            color: var(--brand-primary) !important;
            background: rgba(99, 102, 241, 0.08);
        }

        /* Buttons Style */
        .btn-custom {
            padding: 10px 24px;
            border-radius: 14px;
            font-size: 0.85rem;
            font-weight: 700;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
        }

        .btn-login {
            background: var(--brand-dark);
            color: white !important;
            text-decoration: none;
        }

        .btn-login:hover {
            background: var(--brand-primary);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.25);
            color: white !important;
        }

        .btn-logout {
            background: #fff1f2;
            color: #e11d48 !important;
            border: 1px solid #ffe4e6;
        }

        .btn-logout:hover {
            background: #e11d48;
            color: white !important;
            transform: translateY(-2px);
        }

        /* --- FOOTER --- */
        .footer {
            background: #ffffff;
            padding: 40px 0;
            border-top: 1px solid #f1f5f9;
            margin-top: 80px;
        }

        .footer-text {
            font-weight: 600;
            font-size: 0.75rem;
            color: #94a3b8;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Responsive Mobile */
        @@media (max-width: 991.98px) {
            .navbar { width: 95%; margin: 10px auto; border-radius: 15px; }
            .navbar-collapse { padding-top: 20px; }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNavbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon">
                        <i class="bi bi-layers-half"></i>
                    </div>
                    <span>SMI<span class="text-primary">SYSTEM</span></span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                               asp-controller="Home" asp-action="Index">Beranda</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Docs" ? "active" : "")" 
                               asp-controller="Docs" asp-action="Index">Dokumentasi</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (Context.Session.GetString("AdminUsername") != null)
                        {
                            <a class="nav-link text-primary d-none d-lg-block me-2" asp-controller="Admin" asp-action="Dashboard">
                                <i class="bi bi-grid-1x2-fill me-1"></i> Dashboard
                            </a>
                            <form asp-controller="Admin" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="btn-custom btn-logout">
                                    <i class="bi bi-power"></i> <span>Logout</span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn-custom btn-login" asp-controller="Admin" asp-action="Login">
                                <i class="bi bi-shield-lock-fill"></i> Admin Portal
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container text-center">
            <div class="footer-text">
                PT SEPATU MAS IDAMAN &bull; OPERATIONAL SYSTEM &copy; @DateTime.Now.Year
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(window).scroll(function() {
            if ($(this).scrollTop() > 30) {
                $('#mainNavbar').addClass('scrolled');
            } else {
                $('#mainNavbar').removeClass('scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>